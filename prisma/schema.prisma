generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is managed in prisma.config.ts (Prisma 7)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  DOCTOR
  MAIRE
  SECRETAIRE
  MAINTAINER
}

enum BirthStatus {
  DRAFT             // Doctor saved, not yet submitted
  SUBMITTED         // Doctor submitted to city hall
  PROCESSING        // Secretaire claimed and is completing info
  PENDING_APPROVAL  // Secretaire submitted to Maire
  APPROVED          // Maire approved — certificate generated
  DECLINED          // Maire declined with reason
}

enum Gender {
  MALE
  FEMALE
}

enum DeliveryType {
  NATURAL
  CAESAREAN
  FORCEPS
  VACUUM
}

// ─── Institutions ─────────────────────────────────────────────────────────────

model Hospital {
  id       String  @id @default(cuid())
  name     String
  city     String
  address  String?
  phone    String?
  email    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorAssignments DoctorHospitalAssignment[]
  births            BirthRecord[]
}

model CityHall {
  id       String  @id @default(cuid())
  name     String
  city     String
  address  String?
  phone    String?
  email    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  births BirthRecord[]
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  email     String?  @unique
  firstName String
  lastName  String
  role      UserRole
  isActive  Boolean  @default(true)

  cityHallId String?
  cityHall   CityHall? @relation(fields: [cityHallId], references: [id])

  hospitalAssignments DoctorHospitalAssignment[]

  birthsAsDoctor     BirthRecord[] @relation("BirthDoctor")
  birthsAsSecretaire BirthRecord[] @relation("BirthSecretaire")
  birthsAsMaire      BirthRecord[] @relation("BirthMaire")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Doctor–Hospital assignment ───────────────────────────────────────────────

model DoctorHospitalAssignment {
  id         String    @id @default(cuid())
  userId     String
  hospitalId String
  isApproved Boolean   @default(false)
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([userId, hospitalId])
}

// ─── Birth record ─────────────────────────────────────────────────────────────

model BirthRecord {
  id     String      @id @default(cuid())
  status BirthStatus @default(DRAFT)

  // ── Baby ──────────────────────────────────────────
  babyFirstName String?
  babyLastName  String?
  babyGender    Gender?
  birthDate     DateTime?
  birthTime     String?   // "HH:MM"
  birthPlace    String?   // ward / room

  // ── Medical (doctor) ──────────────────────────────
  weightGrams  Int?
  heightCm     Float?
  apgarScore   Int?
  deliveryType DeliveryType?
  medicalNotes String?

  // ── Mother ────────────────────────────────────────
  motherFirstName   String?
  motherLastName    String?
  motherBirthDate   DateTime?
  motherNationality String?
  motherCni         String?
  motherProfession  String?
  motherAddress     String?
  motherPhone       String?
  motherEmail       String?

  // ── Father ────────────────────────────────────────
  fatherFirstName   String?
  fatherLastName    String?
  fatherBirthDate   DateTime?
  fatherNationality String?
  fatherCni         String?
  fatherProfession  String?
  fatherAddress     String?
  fatherPhone       String?

  // ── Marriage ──────────────────────────────────────
  parentsMarried     Boolean   @default(false)
  marriageCertNumber String?
  marriageDate       DateTime?

  // ── Approval ──────────────────────────────────────
  declineReason     String?
  approvedAt        DateTime?
  declinedAt        DateTime?
  certificateNumber String?   @unique

  // ── Relations ─────────────────────────────────────
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  doctorId String
  doctor   User   @relation("BirthDoctor", fields: [doctorId], references: [id])

  cityHallId   String?
  cityHall     CityHall? @relation(fields: [cityHallId], references: [id])

  secretaireId String?
  secretaire   User?   @relation("BirthSecretaire", fields: [secretaireId], references: [id])

  maireId String?
  maire   User?   @relation("BirthMaire", fields: [maireId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
